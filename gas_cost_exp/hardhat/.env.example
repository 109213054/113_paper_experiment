# Kurtosis RPC endpoint
RPC_URL=http://127.0.0.1:32827

# Deployer private key for local Kurtosis testnet
# Replace with your actual funded test account private key
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Kurtosis chain id
CHAIN_ID=3151908

# Current experiment size
EXPERIMENT_N=10

# Current verifier contract (Hardhat fully qualified name)
VERIFIER_FQN=contracts/verifiers/Verifier_n10.sol:Groth16Verifier

# Deployed contract addresses
# Leave blank before deployment, then update after running deploy_for_n.ts
VERIFIER_ADDRESS=
SETTLEMENT_ADDRESS=

# Output directory for raw gas result JSON files
RESULT_DIR=../results/raw/kurtosis

# ZKP proof/public input paths
PROOF_PATH=../zkp/proofs/n_10/proof.json
PUBLIC_PATH=../zkp/proofs/n_10/public.json
PUBLIC_FAIL_PATH=../zkp/proofs/n_10/public_fail.json

# Settlement testing parameter
ROUND_ID=1
